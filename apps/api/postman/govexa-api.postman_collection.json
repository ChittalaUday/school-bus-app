{
  "info": {
    "name": "Govexa API",
    "description": "Complete API collection for the Govexa student transportation platform.\n\n**Environments:**\n- Local: `http://localhost:3000`\n- Staging: set `govexa_baseUrl` variable accordingly\n\n**Auth:** Most endpoints require `Authorization: Bearer {{govexa_accessToken}}`.\nObtain a token via `POST /api/auth/login` and set the `govexa_accessToken` collection variable.\n\n**Maintenance rule:** Every route added or changed in `apps/api` MUST have a matching\nrequest added or updated here in the same PR. See `docs/repositories/api/RULES.md`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "govexa-api-v1"
  },
  "variable": [
    {
      "key": "govexa_baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "API base URL. Override per environment."
    },
    {
      "key": "govexa_graphhopperUrl",
      "value": "http://localhost:8989",
      "type": "string",
      "description": "GraphHopper routing engine URL."
    },
    {
      "key": "govexa_accessToken",
      "value": "",
      "type": "string",
      "description": "JWT access token. Set after login."
    },
    {
      "key": "govexa_refreshToken",
      "value": "",
      "type": "string",
      "description": "JWT refresh token. Set after login."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{govexa_accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "System",
      "description": "System-level endpoints — health, version, status.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_baseUrl}}/health",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["health"]
            },
            "description": "Returns the liveness status of the API, PostgreSQL, and Redis.\n\n**Auth:** None required.\n\n**200 — all services healthy:**\n```json\n{\n  \"status\": \"ok\",\n  \"version\": \"0.0.1\",\n  \"env\": \"development\",\n  \"services\": {\n    \"database\": \"ok\",\n    \"redis\": \"ok\"\n  }\n}\n```\n\n**503 — one or more services degraded:**\n```json\n{\n  \"status\": \"degraded\",\n  \"services\": {\n    \"database\": \"error\",\n    \"redis\": \"ok\"\n  }\n}\n```"
          },
          "response": [
            {
              "name": "200 — Healthy",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{govexa_baseUrl}}/health",
                  "host": ["{{govexa_baseUrl}}"],
                  "path": ["health"]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"ok\",\n  \"version\": \"0.0.1\",\n  \"env\": \"development\",\n  \"services\": {\n    \"database\": \"ok\",\n    \"redis\": \"ok\"\n  }\n}"
            },
            {
              "name": "503 — Degraded",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{govexa_baseUrl}}/health",
                  "host": ["{{govexa_baseUrl}}"],
                  "path": ["health"]
                }
              },
              "status": "Service Unavailable",
              "code": 503,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"degraded\",\n  \"version\": \"0.0.1\",\n  \"env\": \"development\",\n  \"services\": {\n    \"database\": \"error\",\n    \"redis\": \"ok\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "GraphHopper (Routing Engine)",
      "description": "GraphHopper routing engine endpoints running on port 8989.\nUsed for route calculation, ETA, and rerouting.\nProfiles available: `bus`, `car`, `foot`.\nDataset: Hyderabad region.",
      "item": [
        {
          "name": "GH — Info",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/info",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["info"]
            },
            "description": "Returns GraphHopper server info including available routing profiles, bounding box, and version.\n\n**Auth:** None required."
          },
          "response": [
            {
              "name": "200 — Info",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"bbox\": [78.136424, 17.049139, 78.830896, 17.691684],\n  \"profiles\": [\n    { \"name\": \"car\" },\n    { \"name\": \"bus\" },\n    { \"name\": \"foot\" }\n  ],\n  \"version\": \"12.0\",\n  \"elevation\": false\n}"
            }
          ]
        },
        {
          "name": "GH — Route (Bus Profile)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/route?point=17.385044,78.486671&point=17.440081,78.348915&profile=bus&instructions=true&calc_points=true&points_encoded=false",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["route"],
              "query": [
                { "key": "point", "value": "17.385044,78.486671", "description": "Start: Charminar, Hyderabad" },
                { "key": "point", "value": "17.440081,78.348915", "description": "End: HITEC City, Hyderabad" },
                { "key": "profile", "value": "bus", "description": "Routing profile (bus, car, foot)" },
                { "key": "instructions", "value": "true", "description": "Include turn-by-turn instructions" },
                { "key": "calc_points", "value": "true", "description": "Return route geometry" },
                { "key": "points_encoded", "value": "false", "description": "Return coordinates as plain arrays instead of encoded polyline" }
              ]
            },
            "description": "Calculate a bus route between two points in Hyderabad.\n\n**Auth:** None required.\n\n**Default test route:** Charminar → HITEC City.\n\nReturns distance (meters), time (ms), and turn-by-turn instructions."
          },
          "response": []
        },
        {
          "name": "GH — Route (Car Profile)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/route?point=17.385044,78.486671&point=17.440081,78.348915&profile=car&instructions=true&calc_points=true&points_encoded=false",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["route"],
              "query": [
                { "key": "point", "value": "17.385044,78.486671", "description": "Start: Charminar" },
                { "key": "point", "value": "17.440081,78.348915", "description": "End: HITEC City" },
                { "key": "profile", "value": "car", "description": "Car routing profile" },
                { "key": "instructions", "value": "true" },
                { "key": "calc_points", "value": "true" },
                { "key": "points_encoded", "value": "false" }
              ]
            },
            "description": "Calculate a car route. Same points as bus route for comparison."
          },
          "response": []
        },
        {
          "name": "GH — Route (Multi-Stop Bus)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/route?point=17.385044,78.486671&point=17.4239,78.4738&point=17.440081,78.348915&profile=bus&instructions=true&calc_points=true&points_encoded=false",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["route"],
              "query": [
                { "key": "point", "value": "17.385044,78.486671", "description": "Stop 1: Charminar" },
                { "key": "point", "value": "17.4239,78.4738", "description": "Stop 2: Secunderabad Station" },
                { "key": "point", "value": "17.440081,78.348915", "description": "Stop 3: HITEC City" },
                { "key": "profile", "value": "bus" },
                { "key": "instructions", "value": "true" },
                { "key": "calc_points", "value": "true" },
                { "key": "points_encoded", "value": "false" }
              ]
            },
            "description": "Calculate a multi-stop bus route — simulates a real school bus run with multiple stops.\n\nRoute: Charminar → Secunderabad Station → HITEC City."
          },
          "response": []
        },
        {
          "name": "GH — Route POST (Flexible)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": [\n    [78.486671, 17.385044],\n    [78.4738, 17.4239],\n    [78.348915, 17.440081]\n  ],\n  \"profile\": \"bus\",\n  \"instructions\": true,\n  \"calc_points\": true,\n  \"points_encoded\": false,\n  \"details\": [\"road_class\", \"surface\", \"max_speed\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/route",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["route"]
            },
            "description": "POST-based route request with more options.\n\n**Note:** In POST body, coordinates are `[lon, lat]` (opposite of GET params).\n\nIncludes `details` for road_class, surface, and max_speed per segment."
          },
          "response": []
        },
        {
          "name": "GH — Isochrone (Bus 15min)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/isochrone?point=17.385044,78.486671&profile=bus&time_limit=900&buckets=3",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["isochrone"],
              "query": [
                { "key": "point", "value": "17.385044,78.486671", "description": "Center: Charminar" },
                { "key": "profile", "value": "bus", "description": "Bus routing profile" },
                { "key": "time_limit", "value": "900", "description": "Time limit in seconds (15 minutes)" },
                { "key": "buckets", "value": "3", "description": "Number of isochrone bands (5min, 10min, 15min)" }
              ]
            },
            "description": "Generate isochrone polygons showing areas reachable by bus within 15 minutes from Charminar.\n\nUseful for coverage analysis and stop planning."
          },
          "response": []
        },
        {
          "name": "GH — Matrix (Travel Times)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": [\n    [78.486671, 17.385044],\n    [78.4738, 17.4239],\n    [78.348915, 17.440081],\n    [78.3915, 17.4456]\n  ],\n  \"profile\": \"bus\",\n  \"out_arrays\": [\"times\", \"distances\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_graphhopperUrl}}/matrix",
              "host": ["{{govexa_graphhopperUrl}}"],
              "path": ["matrix"]
            },
            "description": "Compute a distance/time matrix between multiple points.\n\nUseful for optimizing stop order and calculating ETAs between all stops on a route.\n\nReturns NxN matrices of travel times (seconds) and distances (meters)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Authentication endpoints — invite, accept invitation, login, token refresh, logout. OTP phone verification will be added in a later phase.",
      "item": [
        {
          "name": "Invite User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"schooladmin@example.com\",\n  \"role\": \"SCHOOL_ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_baseUrl}}/auth/invite",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["auth", "invite"]
            },
            "description": "Invite a new user by email and role. Sends an invitation email with a 48-hour accept link.\n\n**Auth:** Bearer token required. Caller must have `MANAGE_USERS` permission (SUPER_ADMIN).\n\n**Roles:** `SUPER_ADMIN`, `SCHOOL_ADMIN`, `TRANSPORT_MANAGER`, `DRIVER`, `PARENT`\n\n**201 — Invitation sent:**\n```json\n{\n  \"userId\": \"cuid\",\n  \"email\": \"schooladmin@example.com\",\n  \"role\": \"SCHOOL_ADMIN\",\n  \"expiresAt\": \"2026-06-22T10:00:00.000Z\"\n}\n```\n\n**409 — Email already exists.**"
          },
          "response": [
            {
              "name": "201 — Invitation Sent",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"schooladmin@example.com\",\n  \"role\": \"SCHOOL_ADMIN\"\n}" },
                "url": { "raw": "{{govexa_baseUrl}}/auth/invite", "host": ["{{govexa_baseUrl}}"], "path": ["auth", "invite"] }
              },
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"userId\": \"clx456def\",\n  \"email\": \"schooladmin@example.com\",\n  \"role\": \"SCHOOL_ADMIN\",\n  \"expiresAt\": \"2026-06-22T10:00:00.000Z\"\n}"
            },
            {
              "name": "409 — Email Already Exists",
              "status": "Conflict",
              "code": 409,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"error\": { \"code\": \"CONFLICT\", \"message\": \"A user with this email already exists\" } }"
            }
          ]
        },
        {
          "name": "Accept Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('govexa_accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('govexa_refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<raw-token-from-invite-email>\",\n  \"password\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_baseUrl}}/auth/accept",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["auth", "accept"]
            },
            "description": "Accept an invitation and set a password. The token comes from the invite email link (`/auth/accept?token=...`). Token is valid for 48 hours and single-use.\n\n**Auth:** None.\n\n**200 — Accepted — returns tokens same as login:**\n```json\n{\n  \"accessToken\": \"eyJ...\",\n  \"refreshToken\": \"abc123...\",\n  \"user\": { \"id\": \"cuid\", \"email\": \"schooladmin@example.com\", \"role\": \"SCHOOL_ADMIN\" }\n}\n```\n\n**400 — Token invalid, expired, or already used.**"
          },
          "response": [
            {
              "name": "200 — Invitation Accepted",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"token\": \"<raw-token-from-invite-email>\",\n  \"password\": \"newpassword123\"\n}" },
                "url": { "raw": "{{govexa_baseUrl}}/auth/accept", "host": ["{{govexa_baseUrl}}"], "path": ["auth", "accept"] }
              },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n  \"refreshToken\": \"a1b2c3d4e5f6...\",\n  \"user\": {\n    \"id\": \"clx456def\",\n    \"email\": \"schooladmin@example.com\",\n    \"role\": \"SCHOOL_ADMIN\"\n  }\n}"
            },
            {
              "name": "400 — Invalid or Expired Token",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"error\": { \"code\": \"BAD_REQUEST\", \"message\": \"Invalid or expired invitation token\" } }"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('govexa_accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('govexa_refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"chitalauday@gmail.com\",\n  \"password\": \"changeme123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_baseUrl}}/auth/login",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate with email and password. Returns JWT access token (short-lived) and refresh token (7 days).\n\n**Auth:** None.\n\n**Dev seed:** `chitalauday@gmail.com` / `changeme123` (SUPER_ADMIN)\n\n**200 — Success:**\n```json\n{\n  \"accessToken\": \"eyJ...\",\n  \"refreshToken\": \"abc123...\",\n  \"user\": { \"id\": \"cuid\", \"email\": \"chitalauday@gmail.com\", \"role\": \"SUPER_ADMIN\" }\n}\n```\n\n**401 — Invalid credentials:**\n```json\n{ \"error\": { \"code\": \"UNAUTHORIZED\", \"message\": \"Authentication required\" } }\n```"
          },
          "response": [
            {
              "name": "200 — Login Success",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"chitalauday@gmail.com\",\n  \"password\": \"changeme123\"\n}" },
                "url": { "raw": "{{govexa_baseUrl}}/auth/login", "host": ["{{govexa_baseUrl}}"], "path": ["auth", "login"] }
              },
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n  \"refreshToken\": \"a1b2c3d4e5f6...\",\n  \"user\": {\n    \"id\": \"clx123abc\",\n    \"email\": \"chitalauday@gmail.com\",\n    \"role\": \"SUPER_ADMIN\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('govexa_accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('govexa_refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{govexa_refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_baseUrl}}/auth/refresh",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Exchange a valid refresh token for a new access token and rotated refresh token. Old refresh token is revoked immediately.\n\n**Auth:** None.\n\n**401 — Token invalid, expired, or already revoked.**"
          },
          "response": [
            {
              "name": "200 — New Tokens",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n  \"refreshToken\": \"newtoken456...\",\n  \"user\": { \"id\": \"clx123abc\", \"email\": \"admin@govexa.in\", \"role\": \"SUPER_ADMIN\" }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{govexa_refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{govexa_baseUrl}}/auth/logout",
              "host": ["{{govexa_baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Revoke the refresh token. Access tokens remain valid until they expire (short TTL).\n\n**Auth:** None.\n\n**204 — Token revoked.**"
          },
          "response": [
            {
              "name": "204 — Logged Out",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        },
      ]
    },
