# ─── Database ─────────────────────────────────────────────────────────────────
# connection_limit=10 enforces the max pool size per CONSTRAINTS.md
DATABASE_URL=postgresql://govexa:change_me@localhost:5432/govexa?connection_limit=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── GraphHopper ──────────────────────────────────────────────────────────────
GRAPHHOPPER_URL=http://localhost:8989

# ─── JWT (must be >= 32 characters each) ──────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxx   # required — min 32 chars
JWT_REFRESH_SECRET=change_me_min_32_chars_xxxxxxxxx  # required — min 32 chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
APP_URL=http://localhost:3001

# ─── Email (Mailhog in dev, real SMTP in prod) ────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@govexa.in

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
