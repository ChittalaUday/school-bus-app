# ─── Database ─────────────────────────────────────────────────────────────────
# connection_limit=10 enforces the max pool size per CONSTRAINTS.md
DATABASE_URL=postgresql://govexa:password@localhost:5432/govexa?connection_limit=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (must be >= 32 characters each, per CONSTRAINTS.md) ──────────────────
JWT_SECRET=change-me-at-least-32-characters-long!!
JWT_REFRESH_SECRET=also-change-me-32-chars-minimum!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
