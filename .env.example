# Copy this file to .env and fill in all required values.
# Variables marked "required" have no default and will crash the app at startup.

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=govexa
POSTGRES_USER=govexa
POSTGRES_PASSWORD=change_me            # required
POSTGRES_PORT=5432
DATABASE_URL=postgresql://govexa:change_me@localhost:5432/govexa

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── GraphHopper ──────────────────────────────────────────────────────────────
GRAPHHOPPER_PORT=8989
GRAPHHOPPER_URL=http://localhost:8989

# ─── API (apps/api) ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
APP_URL=http://localhost:3001

JWT_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxx   # required — min 32 chars
JWT_REFRESH_SECRET=change_me_min_32_chars_xxxxxxxxx  # required — min 32 chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Web (apps/web) ───────────────────────────────────────────────────────────
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Dev: run Mailhog with `docker compose --profile dev up -d mailhog`
# Prod: replace with real SMTP credentials (SendGrid, SES, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@govexa.in

# ─── Telegram Bot (optional — OTP and alerts) ─────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here
TELEGRAM_BOT_TOKEN=

# ─── Storage (Phase 8) ────────────────────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
