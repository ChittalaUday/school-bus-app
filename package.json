{
  "name": "govexa",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:shared": "pnpm --filter @govexa/shared build",
    "dev:api": "pnpm build:shared && pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile-parent": "pnpm build:shared && pnpm --filter mobile-parent start",
    "dev:mobile-driver": "pnpm build:shared && pnpm --filter mobile-driver start",
    "android:mobile-parent": "pnpm --filter mobile-parent android",
    "android:mobile-driver": "pnpm --filter mobile-driver android",
    "ios:mobile-parent": "pnpm --filter mobile-parent ios",
    "ios:mobile-driver": "pnpm --filter mobile-driver ios",
    "prebuild:mobile-parent": "pnpm --filter mobile-parent prebuild",
    "prebuild:mobile-driver": "pnpm --filter mobile-driver prebuild",
    "db:generate": "pnpm --filter api db:generate",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:seed": "pnpm --filter api db:seed",
    "db:studio": "pnpm --filter api db:studio",
    "build:api": "pnpm build:shared && pnpm --filter api build",
    "build:web": "pnpm build:shared && pnpm --filter web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm build:shared && pnpm -r typecheck",
    "docker:up": "docker compose up -d postgres redis graphhopper",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d postgres redis graphhopper"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
