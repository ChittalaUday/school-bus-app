{
  "distance_influence": 90,
  "priority": [
    { "if": "max_weight < 5 || max_width < 3 || max_height < 4", "multiply_by": "0" },
    { "if": "road_class == TRACK", "multiply_by": "0" },
    { "if": "bus_access",
      "multiply_by": "1"
    },
    { "else": "", "multiply_by": "0" }
  ],
  "speed": [
    { "if": "road_environment == FERRY", "limit_to": "ferry_speed" },
    { "else_if": "bus_access && car_average_speed < 10", "limit_to": "10" },
    { "else": "", "limit_to": "car_average_speed * 0.9" },
    { "if": "true", "limit_to": "max_speed * 0.9" },
    { "if": "true", "limit_to": "100" },
    { "if": "true", "multiply_by": "0.50" }
  ]
}

